# API Keys for LLM Services
# Copy this file to .env and add your actual API keys
# NEVER commit .env to git

# OpenRouter API Key (Primary - for Claude Code/Cline)
# Get your free API key at: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Alternative: Google Gemini API Key (if using directly)
# Get free key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Alternative: Anthropic Claude API Key (if using directly)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Groq API Key (fast inference, free tier available)
# Get free key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Google Cloud Project (for deployment in later weeks)
GCP_PROJECT_ID=your_gcp_project_id
GCP_REGION=us-central1

# Streamlit Cloud (if deploying to Streamlit)
# STREAMLIT_SHARING_TOKEN=your_token_here

# GitHub Token (for CI/CD if needed)
# GITHUB_TOKEN=your_github_token_here

